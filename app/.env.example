# Backend API URL
# For local development: http://localhost:8001
# For production: your Railway deployment URL
PUBLIC_API_URL=http://localhost:8001

# FMU catalog API URL
# Leave empty to call /api/v1/catalog/... from the DDTLab origin.
# In local development, Vite proxies /api/v1/catalog to http://127.0.0.1:8000.
# You can also use http://127.0.0.1:8000 directly if the API enables browser CORS.
# For production: https://catalog.your-domain.com
PUBLIC_CATALOG_API_URL=

# Optional. Only set this if the catalog service has CATALOG_API_KEYS configured.
PUBLIC_CATALOG_API_KEY=
