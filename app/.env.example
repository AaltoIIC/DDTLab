# Backend API URL
# For local development: http://localhost:8001
# For production: your Railway deployment URL
PUBLIC_API_URL=http://localhost:8001

# FMU catalog API URL
# Leave empty to call /api/v1/catalog/... from the DDTLab origin.
# In local development, Vite proxies /api/v1/catalog to http://127.0.0.1:8000.
# You can also use http://127.0.0.1:8000 directly if the API enables browser CORS.
# For production: https://catalog.your-domain.com
PUBLIC_CATALOG_API_URL=

# Optional. Only set this if the catalog service has CATALOG_API_KEYS configured.
PUBLIC_CATALOG_API_KEY=

# OEM request workflow API.
# Leave as /oem-api in local development; Vite proxies it to http://127.0.0.1:5173.
# For production: https://oem-interface.your-domain.com
PUBLIC_ANALYSIS_REQUEST_API_URL=/oem-api

# Local Vite-only proxy target for /oem-api.
# Set this to the port where the OEM interface dev server is actually running.
OEM_INTERFACE_PROXY_TARGET=http://127.0.0.1:5174

# Fixed SSP template simulation integration.
# These are server-side settings used by /api/simulation/template-run.
TEMPLATE_SIM_PYTHON=python-client/python_venv/bin/python
TEMPLATE_SIM_FILE_SERVICE_URL=https://localhost:5000
TEMPLATE_SIM_TIMESERIES_URL=https://localhost:5002
TEMPLATE_SIM_FILE_SERVICE_USER=cloud
TEMPLATE_SIM_FILE_SERVICE_PASSWORD=My4360006
RABBITMQ_DEFAULT_HOST=localhost
RABBITMQ_DEFAULT_PORT=5672
RABBITMQ_DEFAULT_USER=myuser
RABBITMQ_DEFAULT_PASS=mypassword
TS3_LAUNCHER_STATUS_HISTORY_QUEUE_COUNT=1
